# backend/.env — 本地开发（npm run start:dev）样例
# 用法：cp .env.example .env
# 基础设施用 docker compose up -d postgres redis minio 启动。

# 数据库
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=timex
DATABASE_PASSWORD=timex_dev_password
DATABASE_NAME=timex

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT（本地可用默认；NODE_ENV=production 时会被校验）
JWT_SECRET=timex-dev-secret-key-2024-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
LICENSE_TOKEN_EXPIRES_IN=24h

# CORS（本地开发留空）
CORS_ORIGINS=

# 对象存储（本地 MinIO）
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=timex-uploads
S3_PUBLIC_URL=http://localhost:9000/timex-uploads
S3_PRESIGNED_TTL=900
MAX_UPLOAD_SIZE=104857600

# AI（auto：配了 OPENAI_API_KEY 用 OpenAI，否则探测 Ollama，否则 mock）
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
