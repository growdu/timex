# docker-compose 全栈环境变量样例
# 用法：cp .env.example .env  然后按需修改
# 生产部署：设置 NODE_ENV=production 并提供强密钥。
#   应用在 NODE_ENV=production 下会强制校验：
#     - JWT_SECRET        ≥32 字符且非默认值
#     - DATABASE_PASSWORD 非空且非 "postgres"
#     - S3_SECRET_KEY     非 "minioadmin"
#   不满足直接 FATAL 退出，拒绝启动。

NODE_ENV=development

# 启动时自动应用 scripts/migrations/*.sql（单实例便捷；多实例建议用 `npm run migrate` 一次性 job 并关此项）
RUN_MIGRATIONS_ON_BOOT=true
# 迁移目录（默认 <cwd>/scripts/migrations）
# MIGRATIONS_DIR=

# ── 数据库（PostgreSQL，compose 的 postgres 服务共用同一组凭据）──
DATABASE_USER=timex
DATABASE_PASSWORD=timex_dev_password
DATABASE_NAME=timex

# ── JWT ──（生产必须更换为 ≥32 字符的强随机串）
JWT_SECRET=timex-dev-secret-key-2024-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──（生产填前端域名，逗号分隔，如 https://timex.example.com）
CORS_ORIGINS=

# ── 对象存储（MinIO / S3 兼容，compose 的 minio 服务共用同一组凭据）──
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=timex-uploads
S3_PUBLIC_URL=http://localhost:9000/timex-uploads
S3_PRESIGNED_TTL=900
MAX_UPLOAD_SIZE=104857600

# ── 前端构建参数（VITE_API_URL，构建时注入）──
# 单机 / compose 全栈用相对 /api（经 nginx 反代）；独立 API 域名用 https://api.example.com/api
VITE_API_URL=/api

# ── AI Provider（auto：配了 OPENAI_API_KEY 用 OpenAI，否则探测 Ollama，否则 mock）──
AI_PROVIDER=auto
OPENAI_API_KEY=                   # OpenAI 兼容服务的 key（留空则跳过 OpenAI，走 Ollama/mock）
OPENAI_BASE_URL=https://api.openai.com/v1   # 改这里切换 DeepSeek / Azure / vLLM 等
OPENAI_MODEL=gpt-4o-mini          # 视觉任务建议多模态模型
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── 生产 TLS（Caddy，配合 docker-compose.prod.yml，仅生产需要）──
# DOMAIN=timex.example.com            # 你的域名（生产必填，触发 Let's Encrypt 自动证书）
# LETSENCRYPT_EMAIL=you@example.com   # 证书到期通知邮箱
